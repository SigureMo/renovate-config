{
  "extends": ["config:base", "schedule:weekly", "group:allNonMajor"],
  "labels": ["dependencies"],
  "pin": false,
  "commitMessagePrefix": "⬆️ deps: ",
  "dependencyDashboardTitle": "☑️ Dependency Dashboard",
  "packageRules": [
    {
      "groupName": "dependencies (non-major)",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "description": "Keep npm dev dependencies on latest versions",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "Node.js dev dependencies",
      "groupSlug": "nodejs-dev-dependencies",
      "rangeStrategy": "bump"
    },
    {
      "description": "Keep Cargo dev dependencies on latest versions",
      "matchManagers": ["cargo"],
      "matchDepTypes": ["dev-dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "Rust dev dependencies",
      "groupSlug": "rust-dev-dependencies",
      "rangeStrategy": "bump"
    },
    {
      "description": "Keep Cargo build dependencies on latest versions",
      "matchManagers": ["cargo"],
      "matchDepTypes": ["build-dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "Rust dev dependencies",
      "groupSlug": "rust-dev-dependencies",
      "rangeStrategy": "bump"
    },
    {
      "description": "Keep PEP 735 dev dependency group on latest versions",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependency-groups"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchJsonata": [
        "depType='dependency-groups' and managerData.depGroup='dev'"
      ],
      "groupName": "Python dev dependencies",
      "groupSlug": "python-dev-dependencies",
      "rangeStrategy": "bump"
    }
  ]
}
